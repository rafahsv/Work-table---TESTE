import { useState, useMemo } from "react";
import {
  Button,
  Card,
  CardContent,
  CardDescription,
  CardHeader,
  CardTitle,
  Input,
  Label,
  Table,
  TableBody,
  TableCell,
  TableHead,
  TableHeader,
  TableRow,
  Select,
  SelectContent,
  SelectItem,
  SelectTrigger,
  SelectValue,
  Textarea,
} from "@/components/ui";
import { Calendar, Clock, Plus, Edit, Trash, TrendingUp, Users } from "lucide-react";

function GestaoHoras2026() {
  const [entradas, setEntradas] = useState([
    {
      id: 1,
      data: "2026-01-15",
      horas: 8,
      tarefas: "Desenvolvimento de features do módulo A e revisão de código"
    },
    {
      id: 2,
      data: "2026-01-16",
      horas: 7.5,
      tarefas: "Reunião com equipe e implementação de testes unitários"
    },
    {
      id: 3,
      data: "2026-02-10",
      horas: 9,
      tarefas: "Deploy em produção e correção de bugs críticos"
    },
    {
      id: 4,
      data: "2026-02-11",
      horas: 8.5,
      tarefas: "Documentação técnica e treinamento da equipe"
    },
    {
      id: 5,
      data: "2026-03-01",
      horas: 8,
      tarefas: "Planejamento sprint e desenvolvimento de novas funcionalidades"
    },
    {
      id: 6,
      data: "2026-03-02",
      horas: 7,
      tarefas: "Code review e otimização de performance"
    }
  ]);

  const [formulario, setFormulario] = useState({
    id: null,
    data: "",
    horas: "",
    tarefas: ""
  });

  const [modoEdicao, setModoEdicao] = useState(false);
  const [filtroMes, setFiltroMes] = useState("todos");

  const handleInputChange = (campo, valor) => {
    setFormulario(prev => ({ ...prev, [campo]: valor }));
  };

  const handleSubmit = (e) => {
    e.preventDefault();
    
    if (!formulario.data || !formulario.horas || !formulario.tarefas) {
      alert("Por favor, preencha todos os campos");
      return;
    }

    if (modoEdicao) {
      setEntradas(prev =>
        prev.map(entrada =>
          entrada.id === formulario.id
            ? { ...entrada, data: formulario.data, horas: parseFloat(formulario.horas), tarefas: formulario.tarefas }
            : entrada
        )
      );
      setModoEdicao(false);
    } else {
      const novaEntrada = {
        id: Math.max(...entradas.map(e => e.id), 0) + 1,
        data: formulario.data,
        horas: parseFloat(formulario.horas),
        tarefas: formulario.tarefas
      };
      setEntradas(prev => [...prev, novaEntrada]);
    }

    setFormulario({ id: null, data: "", horas: "", tarefas: "" });
  };

  const handleEditar = (entrada) => {
    setFormulario({
      id: entrada.id,
      data: entrada.data,
      horas: entrada.horas.toString(),
      tarefas: entrada.tarefas
    });
    setModoEdicao(true);
  };

  const handleExcluir = (id) => {
    if (window.confirm("Tem certeza que deseja excluir esta entrada?")) {
      setEntradas(prev => prev.filter(entrada => entrada.id !== id));
    }
  };

  const handleCancelar = () => {
    setFormulario({ id: null, data: "", horas: "", tarefas: "" });
    setModoEdicao(false);
  };

  const entradasFiltradas = useMemo(() => {
    let resultado = [...entradas];
    
    if (filtroMes !== "todos") {
      resultado = resultado.filter(entrada => {
        const mes = entrada.data.substring(5, 7);
        return mes === filtroMes;
      });
    }

    return resultado.sort((a, b) => new Date(b.data) - new Date(a.data));
  }, [entradas, filtroMes]);

  const metricas = useMemo(() => {
    const dataAtual = new Date();
    const mesAtual = String(dataAtual.getMonth() + 1).padStart(2, "0");
    const anoAtual = dataAtual.getFullYear();

    const entradasAno = entradas.filter(e => e.data.startsWith(String(anoAtual)));
    const entradasMes = entradas.filter(e => e.data.startsWith(`${anoAtual}-${mesAtual}`));

    const totalHorasAno = entradasAno.reduce((sum, e) => sum + e.horas, 0);
    const totalHorasMes = entradasMes.reduce((sum, e) => sum + e.horas, 0);
    const totalDias = entradasAno.length;
    const mediaDiaria = totalDias > 0 ? totalHorasAno / totalDias : 0;

    return {
      totalHorasAno: totalHorasAno.toFixed(1),
      totalHorasMes: totalHorasMes.toFixed(1),
      mediaDiaria: mediaDiaria.toFixed(1),
      totalDias
    };
  }, [entradas]);

  const formatarData = (dataStr) => {
    const [ano, mes, dia] = dataStr.split("-");
    return `${dia}/${mes}/${ano}`;
  };

  return (
    <div className="min-h-screen bg-background p-4 md:p-8">
      <div className="max-w-7xl mx-auto space-y-8">
        <div className="flex flex-col md:flex-row md:items-center md:justify-between gap-4">
          <div>
            <h1 className="text-3xl font-semibold text-foreground">Gestão de Horas Trabalhadas</h1>
            <p className="text-muted-foreground mt-1">Controle e análise das suas horas em 2026</p>
          </div>
          <div className="flex items-center gap-2 text-sm text-muted-foreground">
            <Calendar className="w-4 h-4" />
            <span>Ano de 2026</span>
          </div>
        </div>

        <div className="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-4">
          <Card className="bg-gradient-to-br from-blue-500/10 to-blue-600/5 border-blue-200 dark:border-blue-900">
            <CardHeader className="flex flex-row items-center justify-between space-y-0 pb-2">
              <CardTitle className="text-sm font-medium">Total de Horas do Ano</CardTitle>
              <Clock className="h-4 w-4 text-blue-600 dark:text-blue-400" />
            </CardHeader>
            <CardContent>
              <div className="text-2xl font-bold text-blue-600 dark:text-blue-400">{metricas.totalHorasAno}h</div>
              <p className="text-xs text-muted-foreground mt-1">Acumulado em 2026</p>
            </CardContent>
          </Card>

          <Card className="bg-gradient-to-br from-green-500/10 to-green-600/5 border-green-200 dark:border-green-900">
            <CardHeader className="flex flex-row items-center justify-between space-y-0 pb-2">
              <CardTitle className="text-sm font-medium">Total de Horas do Mês</CardTitle>
              <TrendingUp className="h-4 w-4 text-green-600 dark:text-green-400" />
            </CardHeader>
            <CardContent>
              <div className="text-2xl font-bold text-green-600 dark:text-green-400">{metricas.totalHorasMes}h</div>
              <p className="text-xs text-muted-foreground mt-1">Mês atual</p>
            </CardContent>
          </Card>

          <Card className="bg-gradient-to-br from-blue-600/10 to-blue-700/5 border-blue-200 dark:border-blue-900">
            <CardHeader className="flex flex-row items-center justify-between space-y-0 pb-2">
              <CardTitle className="text-sm font-medium">Média de Horas por Dia</CardTitle>
              <Clock className="h-4 w-4 text-blue-700 dark:text-blue-300" />
            </CardHeader>
            <CardContent>
              <div className="text-2xl font-bold text-blue-700 dark:text-blue-300">{metricas.mediaDiaria}h</div>
              <p className="text-xs text-muted-foreground mt-1">Média calculada</p>
            </CardContent>
          </Card>

          <Card className="bg-gradient-to-br from-green-600/10 to-green-700/5 border-green-200 dark:border-green-900">
            <CardHeader className="flex flex-row items-center justify-between space-y-0 pb-2">
              <CardTitle className="text-sm font-medium">Total de Dias Trabalhados</CardTitle>
              <Users className="h-4 w-4 text-green-700 dark:text-green-300" />
            </CardHeader>
            <CardContent>
              <div className="text-2xl font-bold text-green-700 dark:text-green-300">{metricas.totalDias}</div>
              <p className="text-xs text-muted-foreground mt-1">Dias registrados</p>
            </CardContent>
          </Card>
        </div>

        <Card>
          <CardHeader>
            <CardTitle>{modoEdicao ? "Editar Entrada" : "Adicionar Nova Entrada"}</CardTitle>
            <CardDescription>
              {modoEdicao ? "Atualize as informações da entrada selecionada" : "Registre suas horas trabalhadas e tarefas realizadas"}
            </CardDescription>
          </CardHeader>
          <CardContent>
            <form onSubmit={handleSubmit} className="space-y-4">
              <div className="grid grid-cols-1 md:grid-cols-3 gap-4">
                <div className="space-y-2">
                  <Label htmlFor="data">Data</Label>
                  <Input
                    id="data"
                    type="date"
                    value={formulario.data}
                    onChange={(e) => handleInputChange("data", e.target.value)}
                    className="w-full"
                  />
                </div>
                <div className="space-y-2">
                  <Label htmlFor="horas">Horas Trabalhadas</Label>
                  <Input
                    id="horas"
                    type="number"
                    step="0.5"
                    min="0"
                    max="24"
                    value={formulario.horas}
                    onChange={(e) => handleInputChange("horas", e.target.value)}
                    placeholder="Ex: 8.5"
                    className="w-full"
                  />
                </div>
                <div className="space-y-2 md:col-span-1">
                  <Label htmlFor="tarefas">Tarefas Realizadas</Label>
                  <Input
                    id="tarefas"
                    value={formulario.tarefas}
                    onChange={(e) => handleInputChange("tarefas", e.target.value)}
                    placeholder="Descreva as tarefas..."
                    className="w-full"
                  />
                </div>
              </div>
              <div className="flex gap-2">
                <Button type="submit" className="bg-blue-600 hover:bg-blue-700">
                  {modoEdicao ? (
                    <>
                      <Edit className="w-4 h-4 mr-2" />
                      Atualizar
                    </>
                  ) : (
                    <>
                      <Plus className="w-4 h-4 mr-2" />
                      Adicionar
                    </>
                  )}
                </Button>
                {modoEdicao && (
                  <Button type="button" variant="outline" onClick={handleCancelar}>
                    Cancelar
                  </Button>
                )}
              </div>
            </form>
          </CardContent>
        </Card>

        <Card>
          <CardHeader>
            <div className="flex flex-col md:flex-row md:items-center md:justify-between gap-4">
              <div>
                <CardTitle>Histórico de Horas</CardTitle>
                <CardDescription>Visualize e gerencie todas as suas entradas</CardDescription>
              </div>
              <div className="flex items-center gap-2">
                <Label htmlFor="filtro-mes" className="text-sm whitespace-nowrap">Filtrar por mês:</Label>
                <Select value={filtroMes} onValueChange={setFiltroMes}>
                  <SelectTrigger id="filtro-mes" className="w-40">
                    <SelectValue />
                  </SelectTrigger>
                  <SelectContent>
                    <SelectItem value="todos">Todos os meses</SelectItem>
                    <SelectItem value="01">Janeiro</SelectItem>
                    <SelectItem value="02">Fevereiro</SelectItem>
                    <SelectItem value="03">Março</SelectItem>
                    <SelectItem value="04">Abril</SelectItem>
                    <SelectItem value="05">Maio</SelectItem>
                    <SelectItem value="06">Junho</SelectItem>
                    <SelectItem value="07">Julho</SelectItem>
                    <SelectItem value="08">Agosto</SelectItem>
                    <SelectItem value="09">Setembro</SelectItem>
                    <SelectItem value="10">Outubro</SelectItem>
                    <SelectItem value="11">Novembro</SelectItem>
                    <SelectItem value="12">Dezembro</SelectItem>
                  </SelectContent>
                </Select>
              </div>
            </div>
          </CardHeader>
          <CardContent>
            <div className="rounded-md border">
              <Table>
                <TableHeader>
                  <TableRow>
                    <TableHead className="w-32">Data</TableHead>
                    <TableHead className="w-32">Horas</TableHead>
                    <TableHead>Tarefas Realizadas</TableHead>
                    <TableHead className="w-32 text-right">Ações</TableHead>
                  </TableRow>
                </TableHeader>
                <TableBody>
                  {entradasFiltradas.length === 0 ? (
                    <TableRow>
                      <TableCell colSpan={4} className="text-center text-muted-foreground py-8">
                        Nenhuma entrada encontrada. Adicione sua primeira entrada acima.
                      </TableCell>
                    </TableRow>
                  ) : (
                    entradasFiltradas.map((entrada) => (
                      <TableRow key={entrada.id}>
                        <TableCell className="font-medium">{formatarData(entrada.data)}</TableCell>
                        <TableCell>
                          <span className="inline-flex items-center gap-1 text-blue-600 dark:text-blue-400 font-semibold">
                            <Clock className="w-3 h-3" />
                            {entrada.horas}h
                          </span>
                        </TableCell>
                        <TableCell className="max-w-md">{entrada.tarefas}</TableCell>
                        <TableCell className="text-right">
                          <div className="flex justify-end gap-2">
                            <Button
                              variant="outline"
                              size="sm"
                              onClick={() => handleEditar(entrada)}
                              className="text-blue-600 hover:text-blue-700 hover:bg-blue-50 dark:hover:bg-blue-950"
                            >
                              <Edit className="w-4 h-4" />
                            </Button>
                            <Button
                              variant="outline"
                              size="sm"
                              onClick={() => handleExcluir(entrada.id)}
                              className="text-red-600 hover:text-red-700 hover:bg-red-50 dark:hover:bg-red-950"
                            >
                              <Trash className="w-4 h-4" />
                            </Button>
                          </div>
                        </TableCell>
                      </TableRow>
                    ))
                  )}
                </TableBody>
              </Table>
            </div>
            {entradasFiltradas.length > 0 && (
              <p className="text-sm text-muted-foreground mt-4">
                Mostrando {entradasFiltradas.length} {entradasFiltradas.length === 1 ? "entrada" : "entradas"}
              </p>
            )}
          </CardContent>
        </Card>
      </div>
    </div>
  );
}

export default GestaoHoras2026;
